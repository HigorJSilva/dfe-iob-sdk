# Credenciais para teste do SDK emitte/dfe-iob-sdk
# Copie para .env.test e preencha os valores reais

# API key dos módulos DFe (NFC-e, NF-e, NFS-e, CT-e)
IOB_API_KEY=

# Módulo ADM — credenciais OAuth 3 etapas (USM)
IOB_ADM_CLIENT_ID=
IOB_ADM_CLIENT_SECRET=
IOB_ADM_X_API_KEY=
IOB_ADM_USERNAME=
IOB_ADM_PASSWORD=

# CNPJ usado nas consultas de teste por período
IOB_TEST_CNPJ=

# URLs de ambiente (opcional — padrão já aponta para desenvolvimento)
IOB_DFE_NFE_BASE_URL=https://dev-dfe-nfe.iob.com.br
IOB_DFE_NFSE_BASE_URL=https://dev-dfe-nfse.iob.com.br
IOB_DFE_CTE_BASE_URL=https://dev-dfe-cte.iob.com.br
IOB_ADM_BASE_URL=https://dev-dfe-adm.iob.com.br
IOB_USM_BASE_URL=https://development-usm-svc-app.iob.com.br
