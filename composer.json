{
    "name": "emitte/dfe-iob-sdk",
    "description": "SDK PHP para integração com a API Motor de Documentos Fiscais da IOB",
    "type": "library",
    "license": "MIT",
    "keywords": ["iob", "dfe", "nfe", "nfce", "nfse", "cte", "fiscal", "sdk"],
    "authors": [
        {
            "name": "Emitte",
            "email": "dev@emitte.com.br"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Emitte\\DfeIob\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Emitte\\DfeIob\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Emitte\\DfeIob\\DfeIobServiceProvider"
            ],
            "aliases": {
                "DfeIob": "Emitte\\DfeIob\\Facades\\DfeIob"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
